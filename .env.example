# DeepSeek 本地开发环境变量（复制为 .env 并填入密钥，勿提交 .env）
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=

# 可选模型: deepseek-v4-pro | deepseek-v4-flash
# Claude 别名会自动映射: opus→pro, sonnet/haiku→flash
# ANTHROPIC_MODEL=deepseek-v4-flash

# --- CCui 可选开关 ---
# 开发模式：自动信任目录 + 启用增强记忆（start-gui.bat 已默认置 1）
# CLAUDE_CODE_DEV=1
# 记忆召回总开关：1 强制开 / 0 强制关（缺省随 CLAUDE_CODE_DEV）
# CCUI_MEMORY=1
# CCUI_MEMORY_DISABLE=1

# --- L2D vtuber 流水线（l2d-vtuber-host skill，可选）---
# 流水线项目根（含 一键生成.bat / src/cli.py）
# L2D_VDPROD_ROOT=
# sakiko 资源根（含 runtime/python.exe、live2d 模型、reference_audio）
# SAKIKO_ROOT=
