{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@ccui/protocol": ["packages/protocol/index.ts"],
      "@ccui/protocol/*": ["packages/protocol/*"],
      "@ccui/engine-api": ["packages/engine-api/index.ts"],
      "@ccui/engine-memory": ["packages/engine-memory/index.ts"],
      "@ccui/plugin-sdk": ["packages/plugin-sdk/index.ts"],
      "@ccui/plugin-sdk/guest": ["packages/plugin-sdk/guest.js"],
      "src/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@core/*": ["src/core/*"],
      "@commands/*": ["src/commands/*"],
      "@components/*": ["src/components/*"],
      "@services/*": ["src/services/*"],
      "@utils/*": ["src/utils/*"],
      "@tools/*": ["src/tools/*"],
      "@bridge/*": ["src/bridge/*"],
      "@ink/*": ["src/ink/*"]
    },
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "scripts/**/*", "packages/**/*", "services/**/*"],
  "exclude": ["node_modules", "dist"]
}
