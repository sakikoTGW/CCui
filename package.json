{
  "name": "claude-code-ui",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Claude Code 终端 AI 编程助手 — 源码工程化版本",
  "type": "module",
  "main": "src/entrypoints/cli.tsx",
  "scripts": {
    "start": "cmd /c start-gui.bat",
    "gui": "cmd /c start-gui.bat",
    "repl": "bun run scripts/run-deepseek.ts",
    "dev": "bun run scripts/run-deepseek.ts",
    "deepseek": "bun run scripts/run-deepseek.ts",
    "ask": "bun run scripts/deepseek-ask.ts",
    "smoke": "bun run scripts/smoke-test.ts",
    "test:plugins": "bun run scripts/test-plugin-sdk.ts",
    "test:protocol": "bun run scripts/test-protocol.ts",
    "test:unit": "bun run scripts/test-protocol.ts && bun run scripts/test-plugin-sdk.ts",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-ready.ps1",
    "human": "powershell -ExecutionPolicy Bypass -File scripts/simulate-human.ps1",
    "seed-skills": "bun run scripts/seed-ccui-skills.ts",
    "verify:repl": "powershell -ExecutionPolicy Bypass -File scripts/verify-repl-open.ps1",
    "start:repl": "powershell -ExecutionPolicy Bypass -File scripts/start.ps1",
    "start:here": "powershell -ExecutionPolicy Bypass -File scripts/start-terminal.ps1",
    "bootstrap": "bun run scripts/bootstrap-deps.ts",
    "build": "bun run scripts/build.ts",
    "build:indexer": "bun run scripts/build-indexer.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@ant/claude-for-chrome-mcp": "file:./stubs/claude-for-chrome-mcp",
    "@ant/computer-use-input": "file:./stubs/computer-use-input",
    "@ant/computer-use-mcp": "file:./stubs/computer-use-mcp",
    "@ant/computer-use-swift": "file:./stubs/computer-use-swift",
    "@anthropic-ai/claude-agent-sdk": "*",
    "@anthropic-ai/sandbox-runtime": "^0.0.54",
    "@anthropic-ai/sdk": "*",
    "@commander-js/extra-typings": "*",
    "@growthbook/growthbook": "^1.6.5",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "*",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "auto-bind": "^5.0.1",
    "axios": "^1.17.0",
    "bidi-js": "^1.0.3",
    "chalk": "*",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "color-diff-napi": "^0.0.1",
    "diff": "^9.0.0",
    "emoji-regex": "^10.6.0",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "figures": "*",
    "fuse.js": "^7.4.2",
    "get-east-asian-width": "^1.6.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "indent-string": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "*",
    "marked": "^18.0.5",
    "minimatch": "^10.2.5",
    "p-map": "^7.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "*",
    "react-reconciler": "^0.33.0",
    "semver": "^7.8.4",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^5.7.0",
    "usehooks-ts": "^3.1.1",
    "which": "^7.0.0",
    "wrap-ansi": "^10.0.0",
    "xss": "^1.0.15",
    "yaml": "^2.9.0",
    "zod": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "*",
    "typescript": "*"
  }
}
